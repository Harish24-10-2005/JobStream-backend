# ============================================
# JobStream Backend Production Environment
# ============================================

ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

# Comma-separated frontend origins (no localhost in production).
CORS_ORIGINS=https://your-frontend-domain.com
WS_AUTH_REQUIRED=true
TRUST_PROXY_HEADERS=true

# Rate limits and request protection
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60
MAX_REQUEST_SIZE=10485760

# Credits / budget guardrails
CREDIT_SYSTEM_ENABLED=true
CREDIT_DAILY_QUERY_LIMIT=200
CREDIT_DAILY_TOKEN_LIMIT=150000

# Core providers
GROQ_API_KEY=replace_me
SERPAPI_API_KEY=replace_me

# Optional providers
GEMINI_API_KEY=replace_me
OPENROUTER_API_KEY=replace_me
OPENROUTER_API_KEY1=replace_me
GROQ_API_KEY1=replace_me
MISTRAL_API_KEY=replace_me

# Model preferences
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_MODEL=qwen/qwen-2.5-vl-7b-instruct:free
GEMINI_MODEL1=gemini-2.0-flash-exp
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001
RAG_EMBEDDING_DIM=3072

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace_me
SUPABASE_SERVICE_KEY=replace_me
SUPABASE_JWT_SECRET=replace_me

# Redis / Celery (managed Redis recommended in production)
REDIS_URL=rediss://default:password@host:6379/0
CELERY_BROKER_URL=rediss://default:password@host:6379/0
CELERY_RESULT_BACKEND=rediss://default:password@host:6379/0

# Docker compose runtime override used by backend/docker-compose.backend.yml
DOCKER_REDIS_URL=rediss://default:password@host:6379/0

# Security
ENCRYPTION_KEY=replace_with_32_char_or_long_secret
ADMIN_API_KEY=replace_me

# Browser automation
BROWSER_HEADLESS=true

# Optional telemetry
PHOENIX_COLLECTOR_ENDPOINT=
